# MAIN
# ──────────────────────────────────────────────────────────────

ANALYSERS = [
    ("Twitter/X",  analyse_twitter),
    ("YouTube",    analyse_youtube),
    ("Facebook",   analyse_facebook),
    ("Instagram",  analyse_instagram),
    ("LinkedIn",   analyse_linkedin),
]


def main():
    print("=" * 58)
    print("  GIPF Social Media Audience Analysis")
    print(f"  Target: @{TW_USERNAME}  |  Year: {YEAR}")
    print("=" * 58)

    results = []
    for platform, fn in ANALYSERS:
        try:
            results.append(fn())
        except Exception as e:
            print(f"  ! {platform} skipped: {e}")
            results.append(error_row(platform))

    with open(OUTPUT_FILE, "w", newline="", encoding="utf-8-sig") as f:
        writer = csv.DictWriter(f, fieldnames=FIELDNAMES)
        writer.writeheader()
        writer.writerows(results)

    print(f"\nDone. Results saved to: {OUTPUT_FILE}")
    print()
    print("Engagement Grade key:")
    print("  A+ >= 6%  |  A >= 3%  |  B >= 1%  |  C >= 0.5%  |  D < 0.5%")
    print()
    print("Audience Quality Score (0-100):")
    print("  60% — engagement rate (higher = more real, active followers)")
    print("  40% — follower/following ratio (higher = more organic growth)")


if __name__ == "__main__":
    main()
